# MongoDB connection string
# Local:  mongodb://127.0.0.1:27017/userauth
# Atlas:  mongodb+srv://<user>:<password>@cluster0.xxxxx.mongodb.net/userauth
MONGO_URI=mongodb+srv://<user>:<password>@cluster0.xxxxx.mongodb.net/news?appName=Cluster0

# Secret key for signing JWTs — change this to a long random string in production
JWT_SECRET=change_this_to_a_long_random_secret

# Server port (optional, defaults to 3000)
PORT=3000

# Set to "production" when deploying
NODE_ENV=development

# OpenAI API key — used to analyze news articles for quality and bias
OPENAI_API_KEY=your_openai_api_key_here

# News API Keys — register free/paid tiers at each provider
NEWSAPI_KEY=your_newsapi_org_key_here
NEWSAPI_AI_KEY=your_newsapi_ai_key_here
WEBZ_KEY=your_webzio_api_key_here
WORLDNEWS_KEY=your_worldnewsapi_key_here
NEWSDATA_KEY=your_newsdata_key_here
THENEWSAPI_KEY=your_thenewsapi_key_here
